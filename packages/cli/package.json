    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "commander": "^13.0.0",
    "fastify": "^5.0.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
